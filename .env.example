# X-Radar 后端环境变量配置
# 复制此文件为 .env 并填入真实值

# === API 认证 ===
API_TOKEN=your-s...here

# === Redis 连接 ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === MySQL 连接 ===
# DB_TYPE=mysql 启用 MySQL；设为 sqlite 则用本地文件数据库
DB_TYPE=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=xianyu_radar

# === 数据加密密钥 (Fernet 对称加密，用于保护 api_key 和 auth_code) ===
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === CORS ===
CORS_ORIGINS=http://localhost:15001,http://127.0.0.1:15001

# === 默认邮箱配置 (用于 AI 评估结果推送) ===
DEFAULT_EMAIL_SENDER=your-email@qq.com
DEFAULT_EMAIL_RECEIVER=your-email@qq.com
DEFAULT_EMAIL_AUTH_CODE=your-smtp-auth-code
DEFAULT_EMAIL_SERVICE=smtp.qq.com
DEFAULT_EMAIL_PORT=465

# === 默认 AI 模型配置 ===
DEFAULT_MODEL_API_KEY=sk-your-api-key
DEFAULT_MODEL_BASE_URL=https://api.deepseek.com
DEFAULT_MODEL_NAME=deepseek-chat
